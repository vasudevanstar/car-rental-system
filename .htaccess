# InfinityFree Configuration

# 1. Protect sensitive files
<FilesMatch "(\.env|\.sql|composer\.json|composer\.lock|config\.php|Procfile)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 2. Block access to config directory
RewriteEngine On
RewriteRule ^config/.*$ - [F,L]
RewriteRule ^vendor/.*$ - [F,L]

# 3. Basic settings
Options -Indexes
AddDefaultCharset UTF-8

# 4. Handle Uploads
<Directory "uploads">
    AllowOverride None
    Options -ExecCGI
    AddHandler cgi-script .php .php3 .php4 .php5 .php7 .phtml .pl .py .jsp .asp .htm .html .sh .cgi
    <FilesMatch "\.(php|php3|php4|php5|php7|phtml|pl|py|jsp|asp|htm|html|sh|cgi)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</Directory>
